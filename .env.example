APP_NAME=input-messages-dispatcher
APP_ENV_FILE=

TEMP_FILES_DIR=./runtime/tmp

RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=input_messages
RABBITMQ_EXCHANGE=input_messages_exchange
RABBITMQ_EXCHANGE_TYPE=direct
RABBITMQ_QUEUE=input.messages.queue
RABBITMQ_ROUTING_KEY=input.messages
OUTPUT_RABBITMQ_HOST=localhost
OUTPUT_RABBITMQ_PORT=5672
OUTPUT_RABBITMQ_USER=guest
OUTPUT_RABBITMQ_PASSWORD=guest
OUTPUT_RABBITMQ_VHOST=output_messages
OUTPUT_RABBITMQ_EXCHANGE=output_messages_exchange
OUTPUT_RABBITMQ_EXCHANGE_TYPE=direct
OUTPUT_RABBITMQ_QUEUE=output_messages.queue
OUTPUT_RABBITMQ_ROUTING_KEY=output_messages.queue
OUTPUT_TEST_RABBITMQ_EXCHANGE=output_test.events
OUTPUT_TEST_RABBITMQ_ROUTING_KEY=output_test.events
RABBITMQ_HEARTBEAT_SECONDS=60
RABBITMQ_BLOCKED_CONNECTION_TIMEOUT_SECONDS=300
RABBITMQ_PREFETCH_COUNT=10

SQLITE_PATH=./runtime/dispatcher.sqlite3
LOG_FILE_PATH=./logs/dispatcher.log
LOG_MAX_BYTES=1048576
LOG_BACKUP_COUNT=5

GEMINI_MODEL=gemini-3.1-flash-preview
GEMINI_API_KEY=
GOOGLE_API_VERSION=
AI_CONFIDENCE_THRESHOLD=0.7

DEFAULT_LANGUAGE=uk
 
# === API SERVER ===
API_SERVER_HOST=
API_SERVER_PORT=
API_ACCESS_TOKEN=
WORKFLOW_ONE_ACTIVE_CASE_PER_CHAT=true
PLUGIN_EXECUTION_POLICY=highest_score
PLUGIN_MAX_SELECTED_PLUGINS=2

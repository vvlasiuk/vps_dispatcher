{
  "version": "0.2.0",
  "configurations": [
  

    {
      "name": "Debug Dispatcher",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/src/main.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      },
      "args": [
        "--env-file",
        "${workspaceFolder}/.env"
      ],
      "justMyCode": false
    }
  ]
}
